{
  "name": "poe-trade-plus",
  "displayName": "Poe Trade Plus",
  "version": "1.1.8",
  "packageManager": "pnpm@11.3.0",
  "license": "MIT",
  "description": "Poe Trade Plus enhances the Path of Exile trade site with bookmarks, history and result tools.",
  "author": "KroxiLabs",
  "contributors": [
    "louisgv",
    "joacoesteban"
  ],
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "node scripts/wxt-firefox-dev.cjs",
    "whats-new": "node scripts/generate-whats-new.cjs",
    "typecheck": "tsc --noEmit",
    "build:chrome": "node scripts/wxt-runner.cjs build",
    "build:firefox": "node scripts/wxt-runner.cjs build -b firefox",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "version": "node scripts/bump-version.cjs",
    "zip:chrome": "node scripts/wxt-runner.cjs zip",
    "zip:firefox": "node scripts/wxt-runner.cjs zip -b firefox",
    "package:chrome": "pnpm run zip:chrome",
    "package:firefox": "pnpm run zip:firefox",
    "package": "pnpm run package:chrome && pnpm run package:firefox",
    "release:check": "node scripts/release.cjs check",
    "release:prepare": "node scripts/release.cjs prepare",
    "release:publish": "node scripts/release.cjs publish",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "js-base64": "^3.7.8",
    "lucide-static": "^1.7.0",
    "svelte": "^5.56.3",
    "svgo": "^3.3.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@wxt-dev/module-svelte": "^2.0.5",
    "prettier": "3.2.4",
    "typescript": "^5.5.0",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "content-security-policy-parser": "0.6.0",
    "msgpackr": "^1.11.9",
    "@babel/core": "^7.29.7",
    "brace-expansion": "^5.0.6",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1",
    "vite": "^8.0.16",
    "svelte": "^5.56.3"
  }
}
